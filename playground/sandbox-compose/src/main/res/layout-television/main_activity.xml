<?xml version="1.0" encoding="utf-8"?>
<com.sdds.uikit.Drawer xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:sd_drawerPlacement="left"
    app:sd_focusDepended="true"
    app:sd_shiftContent="true"
    android:clipChildren="false"
    android:padding="@dimen/sandbox_main_paddings">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:name="com.sdds.playground.sandbox.core.vs.ComponentListFragment"/>

    <include
        android:id="@+id/main_content"
        layout="@layout/main_activity_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</com.sdds.uikit.Drawer>

